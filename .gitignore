# --------------------
# Node modules
# --------------------
# Ignore node_modules in both root and client folder
/node_modules/
client/node_modules/

# --------------------
# Build outputs
# --------------------
/build/
client/build/
/dist/

# --------------------
# Logs
# --------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --------------------
# Environment variables
# --------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
client/.env
client/.env.local
client/.env.development.local
client/.env.test.local
client/.env.production.local

# --------------------
# IDE / Editor files
# --------------------
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# --------------------
# OS generated files
# --------------------
.DS_Store
Thumbs.db

# --------------------
# Coverage reports
# --------------------
/coverage/
client/coverage/

# --------------------
# Temporary files
# --------------------
*.tmp
*.temp

# --------------------
# Yarn v2 / PnP
# --------------------
.pnp.*
.yarn/*
!.yarn/cache
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# --------------------
# TypeScript cache
# --------------------
*.tsbuildinfo

# --------------------
# Service worker / CRA PWA
# --------------------
/service-worker.js
/precache-manifest.*